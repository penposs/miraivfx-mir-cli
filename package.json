{
  "name": "@miraivfx/mir-cli",
  "version": "0.1.0",
  "description": "Agent-friendly CLI for Miraivfx projects, canvases, models, and canvas nodes.",
  "type": "module",
  "bin": {
    "mir-cli": "dist/cli.js"
  },
  "files": [
    "dist",
    "docs",
    "examples",
    "skills",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "prepare": "npm run build",
    "prepack": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "miraivfx",
    "canvas",
    "cli",
    "codex",
    "claude"
  ],
  "license": "UNLICENSED",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
